rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
                   (request.auth.token.email == "jeremyabiera72@gmail.com" && request.auth.token.email_verified == true);
    }
  }
}
